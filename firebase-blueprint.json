{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Business profile and settings for the user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "businessName": { "type": "string" },
        "email": { "type": "string" },
        "shopPhotoUrl": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "currency": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "businessName", "email"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Invoice generated by the user",
      "type": "object",
      "properties": {
        "invoiceNumber": { "type": "string" },
        "customerId": { "type": "string" },
        "clientName": { "type": "string" },
        "clientEmail": { "type": "string" },
        "clientPhone": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "amountPaid": { "type": "number" },
        "dueAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "sent", "paid"] },
        "paymentStatus": { "type": "string", "enum": ["pending", "partial", "paid"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["userId", "invoiceNumber", "totalAmount"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Client details for the business",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "totalPurchaseValue": { "type": "number" },
        "totalDue": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "phone"]
    },
    "AdCopy": {
      "title": "Ad Copy",
      "description": "AI generated advertisement copy",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "platform": { "type": "string", "enum": ["Facebook", "Instagram", "Google", "WhatsApp"] },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "content"]
    },
    "Logo": {
      "title": "Logo",
      "description": "Logo design saved by the user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "imageUrl"]
    },
    "Product": {
      "title": "Product",
      "description": "Inventory items for the user's business",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "purchasePrice": { "type": "number" },
        "stock": { "type": "number" },
        "lowStockThreshold": { "type": "number" },
        "sku": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "price", "stock"]
    },
    "WhatsAppConfig": {
      "title": "WhatsApp Auto Reply",
      "description": "Auto reply rules for WhatsApp",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "keyword": { "type": "string" },
        "replyMessage": { "type": "string" },
        "enabled": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "keyword", "replyMessage"]
    },
    "SubscriptionPlan": {
      "title": "Subscription Plan",
      "description": "Customizable pricing plan for the platform",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "string" },
        "amount": { "type": "number" },
        "period": { "type": "string" },
        "description": { "type": "string" },
        "features": { "type": "array" },
        "popular": { "type": "boolean" },
        "icon": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["id", "name", "price", "amount"]
    },
    "StaffAccount": {
      "title": "Staff Account",
      "description": "Employee account managed by business owner",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "username": { "type": "string" },
        "role": { "type": "string", "enum": ["sales", "inventory", "billing"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "username", "role"]
    },
    "ActivityLog": {
      "title": "Activity Log",
      "description": "Tracking of system events and logins",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "subjectId": { "type": "string" },
        "subjectName": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "deviceInfo": { "type": "string" }
      },
      "required": ["userId", "subjectId", "action", "timestamp"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Real-time alerts for users",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "createdAt"]
    },
    "ContactRequest": {
      "title": "Contact Request",
      "description": "Inquiries from business owners to platform admin",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "resolved"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "message", "createdAt"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Collection of business owner profiles"
    },
    "invoices": {
      "schema": "Invoice",
      "description": "Collection of generated invoices"
    },
    "ad_copies": {
      "schema": "AdCopy",
      "description": "Collection of AI ad copies"
    },
    "logos": {
      "schema": "Logo",
      "description": "Collection of user-created logos"
    },
    "products": {
      "schema": "Product",
      "description": "Collection of business products and inventory"
    },
    "whatsapp_configs": {
      "schema": "WhatsAppConfig",
      "description": "Collection of auto-reply rules"
    },
    "plans": {
      "schema": "SubscriptionPlan",
      "description": "Collection of system subscription plans managed by root admin"
    },
    "customers": {
      "schema": "Customer",
      "description": "Collection of business clients"
    },
    "staff_accounts": {
      "schema": "StaffAccount",
      "description": "Collection of employee accounts"
    },
    "activity_logs": {
      "schema": "ActivityLog",
      "description": "Collection of logs for audit"
    },
    "notifications": {
      "schema": "Notification",
      "description": "Collection of real-time alerts"
    },
    "contact_requests": {
      "schema": "ContactRequest",
      "description": "Collection of support and contact requests"
    }
  }
}
